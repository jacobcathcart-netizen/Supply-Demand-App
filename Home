import streamlit as st
from snowflake.snowpark.context import get_active_session

st.set_page_config(page_title="Supply demand", layout="wide")
st.title(f"Supply demand :balloon: {st.__version__}")

session = get_active_session()
current_staffing = session.sql("select * from SA.SUPPLY_DEMAND.SUPPLY")

regions = (
    current_staffing.select("REGION")
    .distinct()
    .to_pandas()["REGION"]
    .sort_values()
    .tolist()
)

st.session_state.setdefault("start_month", 1)
st.session_state.setdefault("selected_regions", [])
st.session_state.setdefault("adjustments", {})


st.session_state.setdefault("show_adjustments", False)

st.session_state["start_month"] = st.number_input(
    "Start Month (1-12)",
    min_value=1,
    max_value=12,
    value=int(st.session_state["start_month"]),
    step=1,
)

st.session_state["selected_regions"] = st.multiselect(
    "Select regions",
    options=regions,
    default=st.session_state["selected_regions"],
)

left, right = st.columns([1, 3])
with left:
    if st.button(
        "Set adjustments",
        disabled=len(st.session_state["selected_regions"]) == 0,
        use_container_width=True,
    ):
        st.session_state["show_adjustments"] = True

if st.session_state["show_adjustments"]:
    selected = st.session_state["selected_regions"]
    existing = st.session_state["adjustments"]

    with st.form("adjustments_form"):
        updated = {}
        for r in selected:
            updated[r] = st.number_input(
                f"Headcount adjustment for {r}",
                value=int(existing.get(r, 0)),
                step=1,
                key=f"adj_{r}",
            )

        run = st.form_submit_button("Run scenario", use_container_width=True)

    if run:
        st.session_state["adjustments"] = updated
        st.switch_page("pages/Results.py")

        